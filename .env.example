# ================================
# GERAL
# ================================
NODE_ENV=development                # development | staging | production
APP_PORT=3001                       # Porta da API NestJS
FRONTEND_URL=http://localhost:3000  # URL do frontend (CORS)

# ================================
# BANCO DE DADOS (PostgreSQL — D-01)
# ================================
DATABASE_URL="postgresql://janaina:janaina123@localhost:5432/janaina_modas"
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ================================
# REDIS
# ================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=redis123             # Senha do Redis (usar mesmo valor do docker-compose)

# ================================
# JWT / AUTENTICAÇÃO
# ================================
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRATION=15m                  # Duração do access token
REFRESH_TOKEN_SECRET=your_refresh_secret_here_min_32_chars
REFRESH_TOKEN_EXPIRATION=7d         # Duração do refresh token (D-02: armazenado no banco)
COOKIE_SECRET=your_cookie_secret_here

# ================================
# CLOUDINARY (Imagens)
# ================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=janaina-modas     # Pasta de destino no Cloudinary

# ================================
# MERCADO PAGO (Pagamentos) — Sprint 8
# ================================
MERCADOPAGO_ACCESS_TOKEN=TEST-your_access_token  # Obter em https://www.mercadopago.com.br/developers
MERCADOPAGO_PUBLIC_KEY=TEST-your_public_key       # Chave pública para MP.js no frontend
MERCADOPAGO_WEBHOOK_SECRET=your_webhook_secret    # Configurar no painel MP → Webhooks → Assinatura HMAC
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-your_public_key  # Frontend — tokenização de cartão (RN008)
STORE_CEP=01310100                                # CEP de origem da loja para cálculo de frete

# ================================
# E-MAIL (Resend)
# ================================
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=noreply@janainamodas.com.br
EMAIL_FROM_NAME=Janaina Modas

# ================================
# MELHOR ENVIO (Frete)
# ================================
MELHORENVIO_TOKEN=your_token
MELHORENVIO_SANDBOX=true            # true em dev, false em produção

# ================================
# FRETE FALLBACK (D-08)
# ================================
FALLBACK_SHIPPING_PRICE=15.00       # Frete fixo se Melhor Envio indisponível

# ================================
# SENTRY (Monitoramento)
# ================================
SENTRY_DSN=https://your_dsn@sentry.io/project
SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_DSN=https://your_dsn@sentry.io/project  # Frontend

# ================================
# VIACEP
# ================================
# Sem autenticação — API pública, sem variáveis necessárias

# ================================
# ADMIN (Seed inicial — Sprint 3)
# ================================
ADMIN_EMAIL=admin@janainamodas.com.br
ADMIN_PASSWORD=ChangeMe@2025!       # Alterar obrigatoriamente em produção
